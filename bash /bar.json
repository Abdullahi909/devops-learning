      "parameters": {
        "functionCode": "// Generate available time slots\nconst bookedSlots = $input.item.json.map(booking => booking.time_slot);\n\n// Business hours: 9:00 - 18:00 (30min slots)\nconst allSlots = [];\nfor (let hour = 9; hour < 18; hour++) {\n  allSlots.push(`${hour.toString().padStart(2, '0')}:00`);\n  allSlots.push(`${hour.toString().padStart(2, '0')}:30`);\n}\n\nconst availableSlots = allSlots.filter(slot => !bookedSlots.includes(slot));\n\nconst requestedDate = $('Parse AI Intent').item.json.date || new Date().toISOString().split('T')[0];\n\nreturn {\n  action: 'availability_check',\n  date: requestedDate,\n  available_slots: availableSlots,\n  total_available: availableSlots.length,\n  phone: $('Parse AI Intent').item.json.phone,\n  customer: $('Parse AI Intent').item.json.customer\n};"
      },
      "id": "calculate-availability",
      "name": "Calculate Availability",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2440, 400]
