    {
      "parameters": {
        "functionCode": "// Extract and clean incoming message data\nconst from = $input.item.json.From || '';\nconst body = $input.item.json.Body || '';\nconst messageSid = $input.item.json.MessageSid || '';\n\n// Clean phone number (remove + and whitespace)\nconst phone = from.replace(/[^0-9]/g, '');\n\n// Lowercase message for easier processing\nconst message = body.trim().toLowerCase();\n\nreturn {\n  phone: phone,\n  message: message,\n  original_message: body,\n  message_sid: messageSid,\n  timestamp: new Date().toISOString()\n};"
      },
