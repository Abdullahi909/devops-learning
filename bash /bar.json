        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are an AI assistant for a barber shop. Analyze customer messages and extract intent.\n\nReturn ONLY valid JSON in this exact format:\n{\n  \"intent\": \"book|check_availability|cancel|reschedule|help|chat\",\n  \"date\": \"YYYY-MM-DD or null\",\n  \"time\": \"HH:MM or null\",\n  \"service\": \"haircut|beard|both or null\",\n  \"confidence\": 0.95,\n  \"extracted_info\": \"brief summary\"\n}\n\nCurrent date: {{ $now.toFormat('yyyy-MM-dd') }}\nBusiness hours: Monday-Saturday 9:00-18:00 (Closed Sunday)\nTime slots: 30-minute intervals\n\nExamples:\n\"book me friday 3pm\" → {\"intent\":\"book\",\"date\":\"2024-02-19\",\"time\":\"15:00\",\"service\":\"haircut\",\"confidence\":0.95,\"extracted_info\":\"wants friday 3pm booking\"}\n\"u free tomorrow?\" → {\"intent\":\"check_availability\",\"date\":\"2024-02-17\",\"time\":null,\"service\":null,\"confidence\":0.9,\"extracted_info\":\"checking tomorrow availability\"}\n\"need to cancel\" → {\"intent\":\"cancel\",\"date\":null,\"time\":null,\"service\":null,\"confidence\":0.95,\"extracted_info\":\"wants to cancel appointment\"}"
            },
            {
              "role": "user",
              "content": "={{ $json.message }}"
            }
          ]
        },
        "options": {
          "temperature": 0.3
        }
      },
      "id": "ai-intent",
      "name": "AI Intent Detection",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.3,
      "position": [1560, 300],
